# Miscellaneous
*.class
*.log

# SF-NEW (audit/50 F-50-12): audit/raw/ holds local-only grep dumps that
# accelerate attacker recon if exposed (line/file references for auth tokens,
# secrets, hack/fixme markers). Treat as scratch — never commit.
audit/raw/
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Code generation
*.g.dart
*.freezed.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment variables - NEVER COMMIT!
.env
.env.*
.env.local
.env.development
.env.production
.env.staging

# Supabase
supabase/.temp
supabase/.branches

# Secrets
*.key
*.keystore
android/key.properties

# Firebase Service Account Keys - NEVER COMMIT!
firebase-service-account-key.json
*service-account*.json

# Documentation and debug files
*.md
!README.md
!CLAUDE.md
!SECURITY.md
# Whitelist .claude directory and its .md files (Claude Code configuration)
!.claude/
!.claude/*.md
!.claude/**/*.md
# Ignore Claude memory (local-only, not for git)
.claude/memory.json
.claude/scheduled_tasks.lock
# Whitelist docs directory .md files (project documentation)
!docs/**/*.md
# Whitelist AI knowledge base assets
!assets/kb/
!assets/kb/*.md
# Whitelist audit directory .md files (security/architecture audit notes)
!audit/**/*.md
*.sql
*.stackdump
build_output.txt
supabase/supabase/
coverage/
.firebase/hosting.*.cache
*.backup
*.prod-snapshot
*.dev-snapshot
android/build/

# Cloud Functions compiled output
functions/lib/

# Node v25 JIT compile cache (regenerated on each run)
node-compile-cache/

# Jest worker/transform cache (created in repo root by some test runs)
jest_dx/

# Local MCP server config (IDE-managed)
.mcp.json

# Session scratch dirs (never commit)
.tmp/
functions/.tmp/

# Personal notes vault (local only)
obsidian-vault/
test/golden/**/failures/
