          }
        },
        "lib/firebase_options_staging.dart": {
          "projectId": "bookbed-staging",
          "configurations": {
            "android": "1:584902480248:android:a53609e3e6dc177d94f88d",
            "ios": "1:584902480248:ios:c7e20d5f21438baf94f88d",
            "web": "1:584902480248:web:767f9d3bc1837eea94f88d"
          }
        }
      }
    }
  }
}
