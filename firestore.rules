rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // HELPER FUNCTIONS
    // ========================================================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user owns the resource by owner_id field
    // STRICT: No legacy support - all documents must have valid owner_id
    function isResourceOwner() {
      return isAuthenticated() && resource.data.owner_id == request.auth.uid;
    }

    // Check if user is creating resource as themselves
    // CRITICAL SECURITY: Ensures owner_id in new document matches authenticated user
    function canCreateAsOwner() {
      return isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    // Check if user owns the document by userId param (for user subcollections)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is an admin via custom claims
    function isAdmin() {
      return isAuthenticated() && request.auth.token.isAdmin == true;
    }

    // Check if user is an admin via Firestore document (fallback for web admin dashboard)
    function isAdminFromFirestore() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if user owns the parent property
    // STRICT: No legacy support - property must have valid owner_id
    function isPropertyOwner(propertyId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/properties/$(propertyId)).data.owner_id == request.auth.uid;
    }

    // ========================================================================
    // USERS COLLECTION
    // ========================================================================
    match /users/{userId} {
      // Admin dashboard needs to read all users for management
      allow read: if isOwner(userId) || isAdmin() || isAdminFromFirestore();

      // Users can update their own data, but NOT protected status fields.
      // Admins can update anything.
      // Protected fields: subscription status, trial dates, account type, lifetime license,
      // and admin-elevation fields (`role`, `isAdmin`). `role` was the escalation vector that
      // turned `isAdminFromFirestore()` into a self-claimable admin gate.
      allow create: if (isOwner(userId) && !request.resource.data.keys().hasAny([
          'accountStatus', 'trialStartDate', 'trialExpiresAt',
          'statusChangedAt', 'statusChangedBy',
          'account_type', 'admin_override_account_type',
          'lifetime_license_granted_at', 'lifetime_license_granted_by',
          'role', 'isAdmin',
          // SF-vibe57 H-01: Stripe linkage fields are server-managed (Admin SDK
          // writes in stripeConnect/stripePayment/stripeSubscription). Allowing
          // client writes lets user squat victim's stripeSubscriptionId →
          // customer.subscription.deleted webhook downgrades wrong UID.
          'stripe_account_id', 'stripe_customer_id', 'stripe_connected_at',
          'stripeSubscriptionId', 'stripeCustomerId'
        ])) || isAdmin() || isAdminFromFirestore();
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'accountStatus', 'trialStartDate', 'trialExpiresAt',
          'statusChangedAt', 'statusChangedBy',
          'account_type', 'admin_override_account_type',
          'lifetime_license_granted_at', 'lifetime_license_granted_by',
          'role', 'isAdmin',
          // SF-vibe57 H-01: Stripe linkage fields are server-managed (Admin SDK
          // writes in stripeConnect/stripePayment/stripeSubscription). Allowing
          // client writes lets user squat victim's stripeSubscriptionId →
          // customer.subscription.deleted webhook downgrades wrong UID.
          'stripe_account_id', 'stripe_customer_id', 'stripe_connected_at',
          'stripeSubscriptionId', 'stripeCustomerId'
        ])) || isAdmin() || isAdminFromFirestore();
      allow delete: if isAdmin() || isAdminFromFirestore(); // Users cannot delete themselves directly, must use Cloud Function

      // User data subcollection (profile, company, preferences)
      match /data/{document} {
        allow read: if isOwner(userId) || isAdmin();
        // Same logic as parent document: user can't change status fields.
        allow create: if (isOwner(userId) && !request.resource.data.keys().hasAny([
            'accountStatus', 'trialStartDate', 'trialExpiresAt',
            'statusChangedAt', 'statusChangedBy',
            'account_type', 'admin_override_account_type',
            'lifetime_license_granted_at', 'lifetime_license_granted_by',
            'role', 'isAdmin',
            // SF-vibe57 H-01: same deny-list as parent users/{uid} doc.
            'stripe_account_id', 'stripe_customer_id', 'stripe_connected_at',
            'stripeSubscriptionId', 'stripeCustomerId'
          ])) || isAdmin();
        allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'accountStatus', 'trialStartDate', 'trialExpiresAt',
            'statusChangedAt', 'statusChangedBy',
            'account_type', 'admin_override_account_type',
            'lifetime_license_granted_at', 'lifetime_license_granted_by',
            'role', 'isAdmin',
            // SF-vibe57 H-01: same deny-list as parent users/{uid} doc.
            'stripe_account_id', 'stripe_customer_id', 'stripe_connected_at',
            'stripeSubscriptionId', 'stripeCustomerId'
          ])) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }

      // AI chat sessions subcollection
      // Path: users/{userId}/ai_chats/{chatId}
      match /ai_chats/{chatId} {
        allow read, write: if isOwner(userId);
      }

      // Notifications subcollection
      // Path: users/{userId}/notifications/{notificationId}
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        // Only Cloud Functions can create notifications (via Admin SDK)
        allow create: if false;
        // User can only update isRead field
        allow update: if isOwner(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
        allow delete: if isOwner(userId);
      }

      // Rate limits - only Cloud Functions
      match /rate_limits/{action} {
        allow read: if false;
        allow write: if false;
      }

      // Security events subcollection - user login/logout/password change events
      // Users can create and read their own security events.
      // F-NEW-09: field-shape guard prevents arbitrary attribute injection
      // (audit-trail poisoning). Limits create to the known SecurityEventType
      // payload shape from `lib/core/services/security_events_service.dart`.
      // TODO: bind timestamp to request.time after client switches from
      // Timestamp.fromDate(client_clock) to FieldValue.serverTimestamp().
      match /securityEvents/{eventId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly(
            ['type', 'timestamp', 'deviceId', 'ipAddress', 'location', 'metadata']
          )
          && request.resource.data.type is string
          && request.resource.data.type.size() <= 64;
        allow update, delete: if false; // Immutable audit log
      }

      // Devices subcollection - user device tracking for session management
      // SF-NEW (audit/50 F-50-09): updates restricted to mutable telemetry keys
      // observed in lib/core/services/security_events_service.dart trackDevice()
      // (lastSeenAt + fcmToken on every call; platform stable but rewritten via
      // set(merge:true); appVersion forward-compat). Immutable forensics fields
      // (deviceId, createdAt, userAgent) cannot change once written.
      match /devices/{deviceId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'lastSeenAt', 'fcmToken', 'appVersion', 'platform'
          ]);
        allow delete: if isOwner(userId);
      }
    }

    // User Profiles - LEGACY collection (kept for backwards compatibility)
    // F-NEW-08: mirror the /users/{uid} affectedKeys exclusion so a write
    // here cannot be used to flip role/isAdmin/account_type if any future
    // code path reads /user_profiles/{uid} for those fields.
    match /user_profiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && !request.resource.data.keys().hasAny([
          'accountStatus', 'trialStartDate', 'trialExpiresAt',
          'statusChangedAt', 'statusChangedBy',
          'account_type', 'admin_override_account_type',
          'lifetime_license_granted_at', 'lifetime_license_granted_by',
          'role', 'isAdmin'
        ]);
      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'accountStatus', 'trialStartDate', 'trialExpiresAt',
          'statusChangedAt', 'statusChangedBy',
          'account_type', 'admin_override_account_type',
          'lifetime_license_granted_at', 'lifetime_license_granted_by',
          'role', 'isAdmin'
        ]);
      allow delete: if isOwner(userId);
    }

    // ========================================================================
    // PROPERTIES COLLECTION (MAIN STRUCTURE)
    // ========================================================================
    match /properties/{propertyId} {
      // PUBLIC READ: Properties are public data for widget booking functionality
      // Contains: name, description, location, amenities, images
      // NOTE: owner_id is visible but not sensitive (similar to Airbnb host profiles)
      allow read: if true;
      allow create: if canCreateAsOwner();
      allow update, delete: if isResourceOwner();

      // Units subcollection
      match /units/{unitId} {
        allow read: if true; // Public read for widget
        allow create, update, delete: if isPropertyOwner(propertyId);

        // Bookings subcollection
        // SECURITY: T11c CLOSED (2026-05-22) — clause 1 (`unit_id`+`status`)
        // removed alongside the widget migration to the `getUnitAvailability`
        // callable. Anonymous reads of booking docs are now fully denied.
        //
        // ALLOWED READERS:
        // - Property owner via `isPropertyOwner(propertyId)` (dashboard)
        // - Doc-owner via `owner_id == auth.uid` (legacy check, defense-in-depth)
        // - Admin via collection-group rule (see below)
        // - Stripe poll + Guest view: routed through verifyBookingAccess /
        //   getBookingByStripeSession callables (T11-hotfix-partial, T11c).
        match /bookings/{bookingId} {
          allow read: if
            // Property owner can read ALL bookings in their property's units
            isPropertyOwner(propertyId) ||
            // Owner can read their own bookings (legacy check)
            (isAuthenticated() && resource.data.owner_id == request.auth.uid);
          // SECURITY: Write access requires property ownership AND owner_id integrity
          // This ensures an owner cannot create a booking with a fake owner_id
          allow create: if isPropertyOwner(propertyId) && request.resource.data.owner_id == request.auth.uid;
          // Phase B (audit/78): client-SDK updates may NOT touch status-machine
          // fields. Status transitions go through approveBooking / rejectBooking /
          // cancelBooking / completeBooking callables (Admin SDK bypasses rules).
          // Owner can still edit non-status fields (guest_count, internal_notes,
          // dates via updateBookingAtomic, etc.) via direct SDK or the CF.
          allow update: if isPropertyOwner(propertyId)
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['status','approved_at','rejected_at','rejection_reason','cancelled_at','cancellation_reason','completed_at']);
          allow delete: if isPropertyOwner(propertyId);
        }

        // Daily prices subcollection
        match /daily_prices/{dateStr} {
          allow read: if true; // Public read for widget price display
          allow create, update, delete: if isPropertyOwner(propertyId);
        }

        // Additional services subcollection
        // Path: properties/{propertyId}/units/{unitId}/additional_services/{serviceId}
        match /additional_services/{serviceId} {
          allow read: if true; // Widget needs to read services for display
          allow create, update, delete: if isPropertyOwner(propertyId);
        }
      }

      // Widget settings subcollection
      match /widget_settings/{unitId} {
        allow read: if true; // Widget needs to read settings
        allow create, update, delete: if isPropertyOwner(propertyId);
      }

      // Widget secrets subcollection — owner-only, never publicly readable.
      // Holds fields that MUST NOT leak to anonymous widget visitors:
      //   - ical_export_token         (auth token for getUnitIcalFeed)
      //   - stripe_secret_key         (legacy: per-property Stripe sk_, being phased out)
      //   - resend_api_key            (legacy: per-property Resend key, being phased out)
      // Cloud Functions read via Admin SDK (rules bypass). Owner dashboard reads
      // via this rule for display/management.
      match /widget_secrets/{unitId} {
        allow read, create, update, delete: if isPropertyOwner(propertyId);
      }

      // iCal events subcollection — SF-023 LOCKED 2026-05-22
      // Public widget reads now route through the `getUnitAvailability`
      // callable (functions/src/availability.ts) which serves PII-stripped
      // windows server-side via Admin SDK. Owner reads remain allowed for
      // the dashboard's per-property iCal management screens. All client
      // writes denied — Cloud Functions (icalSync.ts) write via Admin SDK.
      match /ical_events/{eventId} {
        allow read: if isPropertyOwner(propertyId);
        allow write: if false;
      }

      // iCal feeds subcollection (feed configurations)
      // Path: properties/{propertyId}/ical_feeds/{feedId}
      match /ical_feeds/{feedId} {
        allow read: if isPropertyOwner(propertyId);
        allow create, update, delete: if isPropertyOwner(propertyId);
      }
    }

    // ========================================================================
    // COLLECTION GROUP QUERIES
    // Enables cross-property/cross-unit queries for dashboard and widget
    // ========================================================================

    // Collection group: units
    match /{path=**}/units/{unitId} {
      allow read: if true;
      // Writes via property_id lookup
      allow create: if isAuthenticated() &&
        ('property_id' in request.resource.data) &&
        get(/databases/$(database)/documents/properties/$(request.resource.data.property_id)).data.owner_id == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        ('property_id' in resource.data) &&
        get(/databases/$(database)/documents/properties/$(resource.data.property_id)).data.owner_id == request.auth.uid;
    }

    // Collection group: widget_settings
    match /{path=**}/widget_settings/{unitId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        ('property_id' in request.resource.data) &&
        get(/databases/$(database)/documents/properties/$(request.resource.data.property_id)).data.owner_id == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        ('property_id' in resource.data) &&
        get(/databases/$(database)/documents/properties/$(resource.data.property_id)).data.owner_id == request.auth.uid;
    }

    // Collection group: bookings
    // Used by: Owner dashboard, Admin dashboard, Guest bookings (via CF),
    // Widget calendar (via CF), Stripe polling (via CF).
    //
    // SECURITY: T11c CLOSED (2026-05-22) — clause 1 (`unit_id`+`status`)
    // removed alongside widget migration to `getUnitAvailability` callable.
    // Anonymous CG reads are now fully denied. Owner-side analytics queries
    // (which already filter by unit_id+status but run authenticated) still
    // succeed because each matched doc satisfies the `owner_id == auth.uid`
    // clause: an owner's units only contain bookings owned by that owner.
    //
    // ALLOWED ACCESS:
    // 1. Admin: Full access for admin dashboard
    // 2. Owner: Read their own bookings (by owner_id == auth.uid)
    //    - Works with ANY query pattern (unit_id filters, date ranges, etc.)
    //    - Realtime subscriptions, analytics, dashboard - all allowed
    // 3. Stripe poll: getBookingByStripeSession callable (T11-hotfix-partial)
    // 4. Guest view: verifyBookingAccess callable (T11-hotfix-partial)
    // 5. Widget calendar: getUnitAvailability callable (T11c, 2026-05-22)
    match /{path=**}/bookings/{bookingId} {
      allow read: if
        // ADMIN: Full access for admin dashboard
        isAdmin() || isAdminFromFirestore() ||
        // PRIMARY SECURITY: Owner can read ONLY their own bookings
        // This works for ALL query patterns: realtime subscriptions, analytics, etc.
        // Even if query filters by unit_id/check_in, only owner's bookings are returned
        (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      // T11-hotfix-partial (2026-05-18): stripe_session_id + booking_reference public-read clauses removed.
      // T11c (2026-05-22): unit_id + status public-read clause removed.
      // Writes go through specific subcollection path above
    }

    // Collection group: daily_prices
    // Used by: Price calculator, Availability checker
    match /{path=**}/daily_prices/{priceId} {
      allow read: if true;
      // Writes go through specific subcollection path above
    }

    // Collection group: ical_events — SF-023 LOCKED 2026-05-22
    // Anonymous CG reads removed. Owner-side dashboard queries (which use
    // collectionGroup('ical_events').where('property_id', '==', ...)) gate
    // on the property's owner_id. Widget never hits this rule — it routes
    // through the `getUnitAvailability` callable.
    match /{path=**}/ical_events/{eventId} {
      allow read: if isAuthenticated() &&
        ('property_id' in resource.data) &&
        get(/databases/$(database)/documents/properties/$(resource.data.property_id)).data.owner_id == request.auth.uid;
      allow write: if false;
    }

    // Collection group: ical_feeds
    // Used by: Scheduled sync Cloud Function, owner dashboard
    match /{path=**}/ical_feeds/{feedId} {
      // Read requires authentication - only owner should access their feeds
      allow read: if isAuthenticated() &&
        ('property_id' in resource.data) &&
        get(/databases/$(database)/documents/properties/$(resource.data.property_id)).data.owner_id == request.auth.uid;
      // Writes go through specific subcollection path above
    }

    // ========================================================================
    // DEPRECATED TOP-LEVEL COLLECTIONS
    // Kept for backward compatibility - migrate data to subcollections
    // TODO: Remove after confirming no legacy data remains
    // ========================================================================

    // DEPRECATED: Top-level units
    // F-NEW-07: lock create. Read kept for legacy migration tools; existing
    // docs can still be updated/deleted by owner (cleanup path). New writes
    // must go through the subcollection /properties/{p}/units/{u}.
    match /units/{unitId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if isResourceOwner();
    }

    // DEPRECATED: Top-level bookings
    // F-NEW-07: lock create. Subcollection /properties/{p}/units/{u}/bookings/{b}
    // is the only valid write path. Read clause unchanged (T11-hotfix-partial,
    // T11c history) — owner can still read own legacy docs.
    match /bookings/{bookingId} {
      allow read: if
        (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if false;
      allow update, delete: if isResourceOwner();
    }

    // DEPRECATED: Top-level daily_prices
    // F-NEW-07: lock create. Subcollection path is the only valid write.
    match /daily_prices/{priceId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if isResourceOwner();
    }

    // SF-023 (2026-05-22): the DEPRECATED top-level `/ical_events/{eventId}`
    // rule was removed in the same PR that locked the subcollection +
    // collection-group paths. No code path writes to the top-level collection
    // (icalSync.ts targets `properties/{p}/ical_events/{id}`), so the rule
    // is unreachable today; leaving an open `read: if true` after locking
    // the other two surfaces would be a footgun if a future drift writes
    // there. Removed entirely.

    // ========================================================================
    // OTHER COLLECTIONS
    // ========================================================================

    // NOTE: additional_services moved to subcollection at:
    // properties/{propertyId}/units/{unitId}/additional_services/{serviceId}
    // See rule at line ~180

    // SF-NNN platform_connections orphan removed (audit/86 §5 dead-code
    // recommendation). Zero readers/writers in `lib/` or `functions/src/`
    // as of 2026-05-30; rule + collection were never wired up. Deny-all
    // fail-CLOSED in case any straggler docs exist; safe to remove the
    // collection entirely via a separate cleanup task.
    match /platform_connections/{connectionId} {
      allow read, write: if false;
    }

    // DEPRECATED: Root-level iCal feeds
    // iCal feeds are now stored as subcollections: properties/{propertyId}/ical_feeds/{feedId}
    // This rule is kept for backward compatibility with legacy data
    // TODO: Remove after confirming no legacy feeds remain
    match /ical_feeds/{feedId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        get(/databases/$(database)/documents/properties/$(resource.data.property_id)).data.owner_id == request.auth.uid
      );
      allow create: if false; // DISABLED - use subcollection path
      allow update, delete: if isAuthenticated() &&
        ('property_id' in resource.data) &&
        get(/databases/$(database)/documents/properties/$(resource.data.property_id)).data.owner_id == request.auth.uid;
    }

    // SF-023 follow-up (2026-05-22): the `/booking_services/*` collection
    // is unused — `audit/16-chrome-regression-full.md` § 4 confirmed zero
    // readers/writers across functions/src/** and lib/**. The rule (which
    // had `read: if true`, a leaking surface on an empty collection) was
    // removed alongside the orphan CG index in firestore.indexes.json.

    // ========================================================================
    // LOCKED COLLECTIONS - Only Cloud Functions via Admin SDK
    // ========================================================================

    // Login attempts - F-50-02 CLOSED: server-only via Admin SDK.
    // Client previously wrote directly with `allow get, create, update: if true`
    // — anon-exploitable lockout DoS for any email. Writes now routed through
    // `functions/src/loginLockout.ts` callables (recordLoginFailure,
    // getLoginLockoutStatus, clearLoginAttempts) which IP-rate-limit and
    // bound how fast an attacker can bump arbitrary email counters.
    match /loginAttempts/{email} {
      allow read, write: if false;
    }

    // Email verifications - OTP codes
    match /email_verifications/{emailHash} {
      allow read: if false;
      allow write: if false;
    }

    // SF-038: Stripe webhook event dedup — server-only via admin SDK.
    // 30-day TTL via expiresAt field (configure Firestore TTL policy on this field).
    match /stripe_webhook_events/{eventId} {
      allow read, write: if false;
    }

    // Email templates - locked for future use
    match /email_templates/{templateId} {
      allow read: if false;
      allow write: if false;
    }

    // Tenants - locked for future use
    match /tenants/{tenantId} {
      allow read: if false;
      allow write: if false;
    }

    // App config - version control and force update settings
    // Read-only for authenticated users (mobile apps fetch version)
    // Only Cloud Functions can write (via Admin SDK)
    // SF-vibe57 M-05: bound platform IDs so a future doc at
    // app_config/internal_keys (or any non-platform id) cannot be enumerated
    // by any authed user. Read still open to authenticated mobile clients for
    // the 3 canonical platform docs only.
    match /app_config/{platform} {
      allow read: if isAuthenticated()
        && platform in ['android', 'ios', 'web'];
      allow write: if false; // Only Cloud Functions via Admin SDK
    }

    // Security events - admin actions and security audit trail
    // Admins can read all events (for Activity Log screen)
    // Authenticated users can create events for their own actions
    // Cloud Functions write via Admin SDK (bypasses rules)
    // SF-vibe57 M-04: bind userId field to caller + cap shape parity with
    // users/{uid}/securityEvents subcollection. Pre-fix any authed user could
    // forge entries about another userId, poisoning admin Activity Log.
    match /security_events/{eventId} {
      allow read: if isAdmin() || isAdminFromFirestore();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(
          ['userId', 'type', 'timestamp', 'deviceId', 'ipAddress', 'location', 'metadata']
        )
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 64;
      allow update, delete: if false; // Immutable audit log
    }

    // OAuth states - for Booking.com/Airbnb integration
    // Handled by Cloud Functions only (Admin SDK bypasses rules)
    match /oauth_states/{state} {
      allow read, write: if false;
    }

    // Sync failures - for iCal sync monitoring
    // Handled by Cloud Functions only (Admin SDK bypasses rules)
    match /sync_failures/{failureId} {
      allow read, write: if false;
    }
  }
}
