{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js",
    "test:rules": "firebase emulators:exec --only firestore --project demo-bookbed-rules 'jest --config jest.config.js --testPathPatterns=test/firestore_rules --testPathIgnorePatterns=/node_modules/ --runInBand'"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@sentry/node": "^10.39.0",
    "bcrypt": "^6.0.0",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "node-ical": "^0.26.1",
    "resend": "^6.9.2",
    "rrule": "^2.8.1",
    "stripe": "^19.1.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase": "^10.14.1",
    "firebase-functions-test": "^3.1.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "undici": "^7.0.0"
  },
  "private": true
}