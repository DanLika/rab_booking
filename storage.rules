rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User-specific files (profile images, unit images, etc.)
    // Path: users/{userId}/...
    //
    // SF-091 (2026-05-30): split `allow write` → `create, update` + `delete`.
    // `request.resource` is null on DELETE, so the old combined rule with
    // `request.resource.size < ...` + `.contentType.matches(...)` evaluates
    // those clauses against null and silently denies every legit owner DELETE
    // (F-91-02). Size/content-type gates only make sense for inbound bytes.
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // SEC-002: File validation — max 10MB, images only.
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif|heic|heif)');

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Property images (public read for widget display)
    // Path: properties/{propertyId}/...
    //
    // SF-091 (2026-05-30): three issues collapsed into one rewrite.
    //   1) The Firestore lookup must use `firestore.get(...)` — plain `get()`
    //      is Firestore-rules-only and silently evaluates to null in Storage
    //      rules (the deploy compiler emits `[W] Invalid function name: get`
    //      but still releases). Pre-fix `get(...)` → ownership check always
    //      false → every owner write to `properties/**` was silently denied
    //      since SEC-001 landed (Jan 7, 2026). Hidden because clients
    //      actually upload property images to `users/{uid}/properties/{pid}/`
    //      via `lib/core/services/storage_service.dart:135` and only fall
    //      back to `properties/...` paths in legacy/admin flows.
    //   2) `$(database)` is unbound in Storage rules — must be literal
    //      `(default)` per Firebase docs.
    //   3) DELETE was bundled with write+size+contentType gates that
    //      evaluate against null `request.resource` → silent DELETE deny
    //      across all rule blocks (F-91-02). Split into `create, update` +
    //      `delete`.
    match /properties/{propertyId}/{allPaths=**} {
      allow read: if true;

      // SEC-001: ownership enforced via Firestore lookup. SEC-002: size + type.
      allow create, update: if request.auth != null
        && firestore.get(/databases/(default)/documents/properties/$(propertyId)).data.owner_id == request.auth.uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif|heic|heif)');

      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/properties/$(propertyId)).data.owner_id == request.auth.uid;
    }

    // iCal exports — SF-025 LOCKED 2026-05-22, SF-091 rewrite 2026-05-30
    // Path: ical-exports/{propertyId}/{unitId}/calendar.ics
    //
    // SF-025: anonymous GET path-guess against this deterministic path used
    // to leak guest names from the .ics SUMMARY field. Rule-mediated reads
    // now require auth + ownership; owner-held tokenized download URLs
    // (`getDownloadURL()`) still work because download tokens bypass rules.
    //
    // SF-091 (2026-05-30): same triple as `properties/**` block above —
    // `get` → `firestore.get`, `$(database)` → `(default)`, write → split
    // into create/update + delete. Owner write/delete/read-via-SDK to this
    // path were all silently denied since SF-025 landed; failures hidden by
    // `ical_export_service.dart:131-137` `autoRegenerateIfEnabled()` catch
    // (only surface = stale .ics feeds, never a user-visible error).
    //
    // 5 MiB cap kept — a real calendar.ics is < 200 KB (one VEVENT per
    // booking, ~250 bytes); 5 MiB is an order-of-magnitude safety bound.
    match /ical-exports/{propertyId}/{unitId}/{allPaths=**} {
      allow read: if request.auth != null
        && firestore.get(/databases/(default)/documents/properties/$(propertyId)).data.owner_id == request.auth.uid;

      allow create, update: if request.auth != null
        && firestore.get(/databases/(default)/documents/properties/$(propertyId)).data.owner_id == request.auth.uid
        && request.resource.size < 5 * 1024 * 1024;

      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/properties/$(propertyId)).data.owner_id == request.auth.uid;
    }

    // Public assets (logos, default images, etc.)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Only admin via Firebase console
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
